# ─── Version Control ──────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Environment (JANGAN masukkan .env ke image!) ─────────
.env

# ─── Node / Frontend ──────────────────────────────────────
node_modules
npm-debug.log
yarn-error.log

# ─── PHP Dev Tools ────────────────────────────────────────
vendor
composer.phar

# ─── Testing ──────────────────────────────────────────────
tests
phpunit.xml
.phpcs.xml

# ─── IDE / Editor ─────────────────────────────────────────
.idea
.vscode
*.DS_Store
Thumbs.db

# ─── Docker files sendiri (tidak perlu di-copy ke container)
Dockerfile
docker-compose.yml
docker-compose*.yml

# ─── Instalasi & Script (tidak dibutuhkan di runtime) ─────
install*.sh
setup_nginx.sh
update.sh
seed_hero.php
TUTORIAL_INSTALASI.md
README.md
walkthrough*.md

# ─── Storage (data runtime, di-mount via volume) ──────────
storage/app/public/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
bootstrap/cache/*

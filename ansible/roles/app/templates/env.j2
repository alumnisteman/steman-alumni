APP_NAME="Alumni STEMAN"
APP_ENV=production
APP_KEY={{ vault_app_key }}
APP_DEBUG=false
APP_URL=https://{{ project_domain }}

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=steman_alumni
DB_USERNAME=app_user
DB_PASSWORD={{ vault_db_password }}
DB_ROOT_PASSWORD={{ vault_db_root_password }}

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=123456
REVERB_APP_KEY=steman-reverb-key
REVERB_APP_SECRET={{ vault_reverb_app_secret }}
REVERB_HOST="{{ project_domain }}"
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME={{ vault_mail_username }}
MAIL_PASSWORD={{ vault_mail_password }}
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS={{ vault_mail_username }}
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID={{ vault_google_client_id }}
GOOGLE_CLIENT_SECRET={{ vault_google_client_secret }}
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

LINKEDIN_CLIENT_ID={{ vault_linkedin_client_id }}
LINKEDIN_CLIENT_SECRET={{ vault_linkedin_client_secret }}

MEILISEARCH_KEY={{ vault_meilisearch_key }}

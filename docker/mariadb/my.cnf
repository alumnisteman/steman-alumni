[mysqld]
# === STEMAN ALUMNI - MariaDB Performance Tuning ===
# Dioptimalkan untuk VPS kecil-menengah, skala aplikasi alumni

# InnoDB Buffer Pool — simpan data dan index di memori (80% dari 512MB limit)
innodb_buffer_pool_size = 384M
innodb_buffer_pool_instances = 2

# Log file size — turunkan I/O flush frequency
innodb_log_file_size = 128M
innodb_log_buffer_size = 16M

# Flush mode — durabilitas vs performa (2 = OS cache flush, cocok untuk VPS)
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# Koneksi dan thread
max_connections = 100
thread_cache_size = 16
thread_stack = 256K

# Query cache — MariaDB 10.6 masih support
query_cache_type = 1
query_cache_size = 32M
query_cache_limit = 2M

# Slow query logging — deteksi query lambat
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow_queries.log
long_query_time = 2
log_queries_not_using_indexes = 1
min_examined_row_limit = 100

# Temp table optimization
tmp_table_size = 64M
max_heap_table_size = 64M

# Sort dan join buffer
sort_buffer_size = 2M
join_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 2M

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Batas ukuran paket (untuk import data besar)
max_allowed_packet = 64M

[client]
default-character-set = utf8mb4

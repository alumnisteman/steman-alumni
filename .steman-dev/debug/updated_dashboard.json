{
  "id": null,
  "uid": "steman-overview",
  "title": "Steman Alumni - System Overview",
  "tags": [
    "steman",
    "alumni"
  ],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Alumni Terdaftar",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "steman_alumni_total",
          "legendFormat": "Alumni"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "steman_http_errors_total",
          "legendFormat": "Errors"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Users (Online)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "steman_alumni_online",
          "legendFormat": "Online"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "steman_disk_used_percent",
          "legendFormat": "Disk %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Queue Length",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "steman_queue_length",
          "legendFormat": "Queue Jobs"
        }
      ]
    },
    {
      "id": 6,
      "title": "System Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "steman_memory_used_mb",
          "legendFormat": "Memory (MB)"
        }
      ]
    },
    {
      "id": 10,
      "title": "Security: Brute Force & Login Failures",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(steman_failed_logins_total[5m])",
          "legendFormat": "Failures/sec"
        },
        {
          "expr": "steman_throttled_logins_total",
          "legendFormat": "Throttled"
        }
      ]
    },
    {
      "id": 11,
      "title": "Guardian: Self-Healing & Bot Detection",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "steman_self_healing_events_total",
          "legendFormat": "Healing Events"
        },
        {
          "expr": "steman_bot_detections_total",
          "legendFormat": "Bots Blocked"
        }
      ]
    },
    {
      "id": 20,
      "title": "Registration Funnel",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "steman_registration_status{status=\"pending\"}",
          "legendFormat": "Pending"
        },
        {
          "expr": "steman_registration_status{status=\"approved\"}",
          "legendFormat": "Approved"
        }
      ]
    },
    {
      "id": 21,
      "title": "Top Alumni (Leaderboard)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 20
      },
      "targets": [
        {
          "expr": "steman_top_alumni_points",
          "format": "table"
        }
      ]
    },
    {
      "id": 30,
      "title": "Alumni by City",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "steman_alumni_by_city",
          "legendFormat": "{{city}}"
        }
      ]
    }
  ]
}